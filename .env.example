# PLM生产数据库配置（只读权限）
# 支持的数据库类型: oracle, mysql, postgresql, sqlserver
PLM_DB_TYPE=oracle
PLM_DB_HOST=192.168.1.111
PLM_DB_PORT=1521
PLM_DB_NAME=sycpcdb
PLM_DB_USER=cpcbase
PLM_DB_PASSWORD=inrpt

# PLM只读同步库配置
SYNC_DB_TYPE=mysql
SYNC_DB_HOST=localhost
SYNC_DB_PORT=3306
SYNC_DB_NAME=plm_sync_db
SYNC_DB_USER=sync_user
SYNC_DB_PASSWORD=11555

# 同步配置
SYNC_INTERVAL_HOURS=24
SYNC_BATCH_SIZE=1000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/bom_check.log

# 报告配置
REPORT_OUTPUT_DIR=reports

# Excel读取模式
# auto: Linux走明文Excel解析；Windows在启用下方开关后走Excel COM读取
# plain: 始终按标准明文Excel解析
# windows_com: 强制使用Windows Excel COM读取（仅Windows可用）
BOM_EXCEL_READER_MODE=auto

# Windows Server 2016 + 绿盾加密场景：
# 设置为true后，Windows环境会启用Excel COM读取受控文件
WINDOWS_ENCRYPTED_EXCEL_ENABLED=false
